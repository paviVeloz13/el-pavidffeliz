{
  "name": "ilovepavidf",
  "version": "0.1.0",
  "description": "iLovePaviDF — offline PDF and image tools",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.ilovepavidf.app",
    "productName": "iLovePaviDF",
    "directories": {
      "output": "dist-electron"
    },
    "extraResources": [
      {
        "from": "../python/dist/ilovepavidf-worker",
        "to": "python-worker",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "win": {
      "target": [{ "target": "nsis" }]
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
